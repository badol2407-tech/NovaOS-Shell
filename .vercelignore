# Ignore all node_modules — Vercel installs deps fresh during build
node_modules
**/node_modules

# Build outputs (Vercel builds these itself)
dist
**/dist
artifacts/novaos/dist
artifacts/api-server/dist

# Replit-specific files
.replit
.replit-artifact
**/.replit-artifact
.upm
.cache
.config

# Migration backup — not needed for Vercel
.migration-backup

# Test / local tooling
coverage
*.log
.env.local

# Large binary / generated assets
attached_assets
